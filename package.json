    "@remotion/layout-utils": "^4.0.481",
    "@remotion/lottie": "^4.0.481",
    "@remotion/motion-blur": "^4.0.481",
    "@remotion/paths": "^4.0.481",
    "@remotion/renderer": "4.0.481",
    "@remotion/shapes": "^4.0.481",
    "@remotion/transitions": "^4.0.481",
    "better-sqlite3": "^12.11.1",
    "culori": "^4.0.2",
    "d3-geo": "^3.1.1",
    "d3-shape": "3.2.0",
    "express": "^5.2.1",
    "flubber": "^0.4.2",
    "matter-js": "^0.20.0",
    "object-hash": "3.0.0",
    "pixi-dragonbones-runtime": "8.0.3",
    "pixi-filters": "^6.1.5",
    "pixi.js": "8.19.0",
    "puppeteer-core": "^25.3.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.481",
    "rss-parser": "^3.13.0",
    "simplex-noise": "4.0.3",
    "topojson-client": "^3.1.0",
    "yaml": "2.7.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "3.24.1"
  },
  "devDependencies": {
    "@types/culori": "^4.0.1",
