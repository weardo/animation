{
  "name": "animation-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Code-driven, Kurzgesagt-style 2.5D deterministic animation pipeline: story script in, video out.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "render": "tsx src/cli/render.ts",
    "frames": "tsx src/cli/render.ts",
    "build:blip": "tsx src/cli/render.ts examples/character.yaml --project blip-intro --name \"Meet Blip\"",
    "build:neuron": "tsx src/cli/render.ts examples/neuron.yaml --project neuron-demo --name \"Neuron\"",
    "factory:gen": "tsx factory-gen-entry.ts",
    "factory:gen-preset": "tsx src/cli/factory-gen-preset.ts",
    "factory:ingest-icons": "tsx ingest-icons-entry.ts",
    "factory:imagegen": "tsx src/cli/imagegen.ts",
    "factory:bundle": "tsx src/cli/factory-bundle.ts",
    "factory:list": "tsx src/cli/factory-list.ts",
    "factory:publish-library": "tsx src/cli/publish-library.ts",
    "factory:fetch-library": "tsx src/cli/fetch-library.ts",
    "export:otio": "tsx src/cli/export-otio.ts",
    "compare": "node tools/perceptual-diff.mjs",
    "studio": "tsx api/server.ts",
    "generate": "tsx api/generate-cli.ts",
    "factory:generate": "tsx api/generate-cli.ts",
    "factory:publish": "tsx src/cli/publish.ts",
    "factory:photo": "tsx src/cli/photo.ts",
    "factory:newsshot": "tsx src/cli/newsshot.ts",
    "factory:newsclip": "tsx src/cli/newsclip.ts",
    "mcp": "tsx mcp-server/index.ts",
    "mcp:smoke": "tsx mcp-server/_smoke.mts",
    "radar": "tsx radar/radar.ts",
    "radar:smoke": "tsx radar/radar.smoke.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
