    "@types/express": "^5.0.6",
    "@types/matter-js": "^0.20.2",
    "@types/node": "22.10.5",
    "@types/object-hash": "3.0.6",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/topojson-client": "^3.1.5",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
