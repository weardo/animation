# Dependencies
node_modules/

# Build output
dist/
build/
*.tsbuildinfo

# Pipeline + render artifacts (regenerated; not source of truth)
.cache/
out/
*.mp4
*.webm

# Project media outputs (regenerable from scene.json + project.lock; the project descriptor,
# story.yaml, scene.json and project.lock ARE tracked for reproducibility).
projects/*/media/

# Remotion
.remotion/

# Local / editor / OS
.vscode/
.claude/settings.local.json
.env
.env.*
!.env.example
*.log
npm-debug.log*
.DS_Store

# Prototype generated artifacts (shapes.mjs is the source; these are regenerated)
prototype/frames/
prototype/preview.html
prototype/preview.svg
prototype/anim.gif

# Factory: keep .spec.json + .preview.png (shareable artifacts); ignore the intermediate preview SVG
library/**/*.preview.svg

# Keep: library/ assets, library/index.json, animation.lock, golden fixtures, docs/
.render-tmp/
.venv-tts/
.venv-*/
tts-proto/
style-ref/
.wf-*.js
.install-*.sh
.m4-*.sh
*.log
public/generated/
