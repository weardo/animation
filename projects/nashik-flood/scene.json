    {
      "id": "narration-hook",
      "kind": "narration",
      "src": "audio://audio/6efeae1a1c0e8ba0.wav",
      "at": 0,
      "duration_frames": 168,
      "transcript": "दोस्तों, ज़रा सोचिए — सिर्फ़ एक दिन में नासिक के Igatpuri में 729 millimetre बारिश गिरी।"
    },
    {
      "id": "narration-scale",
      "kind": "narration",
      "src": "audio://audio/cf33a57da301ac4b.wav",
      "at": 163,
      "duration_frames": 174,
      "transcript": "पूरा ज़िला पानी-पानी हो गया — Trimbakeshwar में 150, और नासिक शहर में 107 millimetre।"
    },
    {
      "id": "narration-godavari",
      "kind": "narration",
      "src": "audio://audio/e5b48344dfd4d7d1.wav",
      "at": 335,
      "duration_frames": 169,
      "transcript": "इतनी बारिश से पवित्र गोदावरी नदी उफान पर आ गई, और Ramkund के घाट और मंदिर पानी में डूब गए।"
    },
    {
      "id": "sfx-godavari-beat0",
      "kind": "sfx",
      "src": "audio://audio/boom.wav",
      "at": 338,
      "duration_frames": 26,
      "volume": 0.38
    },
    {
      "id": "narration-dams",
      "kind": "narration",
      "src": "audio://audio/54b00123b80328d2.wav",
      "at": 501,
      "duration_frames": 202,
      "transcript": "ऊपर से dams भर गए — Nandur Madhyameshwar से दो लाख cusec से ज़्यादा पानी छोड़ा गया, और नदियाँ और चढ़ गईं।"
    },
    {
      "id": "sfx-dams-beat0",
      "kind": "sfx",
      "src": "audio://audio/whoosh.wav",
      "at": 503,
      "duration_frames": 17,
      "volume": 0.55
    },
    {
      "id": "narration-impact",
      "kind": "narration",
      "src": "audio://audio/d3a1103f00bad22a.wav",
      "at": 700,
      "duration_frames": 168,
      "transcript": "शहर में 27 पेड़ धराशायी हो गए, सड़कें धंस गईं, और Mumbai-नासिक की trains घंटों लेट हो गईं।"
    },
    {
      "id": "narration-warning",
      "kind": "narration",
      "src": "audio://audio/d7beb18d0e38a858.wav",
      "at": 866,
      "duration_frames": 187,
      "transcript": "प्रशासन ने नदी किनारे रहने वालों को alert कर दिया — मवेशी और सामान सुरक्षित जगह ले जाने की चेतावनी दी।"
    },
    {
      "id": "narration-close",
      "kind": "narration",
      "src": "audio://audio/cad2696d2f1b138e.wav",
      "at": 1050,
      "duration_frames": 218,
      "transcript": "पर हर मानसून यही कहानी दोहराती है। तो सोचिए — क्या हमारे शहर इस बाढ़ के लिए सच में तैयार हैं? नीचे comment में ज़रूर बताइए।"
    }
  ],
