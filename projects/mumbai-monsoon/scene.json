  "audio": [
    {
      "id": "narration-hook",
      "kind": "narration",
      "src": "audio://audio/7d1e0048ed2ae44d.wav",
      "at": 0,
      "duration_frames": 126,
      "transcript": "दोस्तों, इस बार Mumbai में बारिश सिर्फ़ पानी नहीं लाई — अपने साथ मौत लेकर आई।"
    },
    {
      "id": "narration-rain",
      "kind": "narration",
      "src": "audio://audio/46a5df2da21a32f5.wav",
      "at": 166,
      "duration_frames": 166,
      "transcript": "सिर्फ़ 24 घंटे में 200 millimetre से ज़्यादा बारिश गिरी, पूरा शहर थम गया, और red alert जारी हो गया।"
    },
    {
      "id": "narration-collapse",
      "kind": "narration",
      "src": "audio://audio/f45f6556a0782777.wav",
      "at": 407,
      "duration_frames": 154,
      "transcript": "फिर रात के करीब साढ़े आठ बजे, Mankhurd के Janta Nagar में एक chawl भरभरा कर गिर गई।"
    },
    {
      "id": "sfx-collapse-beat0",
      "kind": "sfx",
      "src": "audio://audio/boom.wav",
      "at": 411,
      "duration_frames": 26,
      "volume": 0.38
    },
    {
      "id": "narration-cost",
      "kind": "narration",
      "src": "audio://audio/7f020a1ad46884dc.wav",
      "at": 591,
      "duration_frames": 126,
      "transcript": "मलबे में दबकर छह लोगों की जान चली गई — जिनमें पाँच मासूम बच्चे थे।"
    },
    {
      "id": "narration-illegal",
      "kind": "narration",
      "src": "audio://audio/153612293e957cc3.wav",
      "at": 751,
      "duration_frames": 173,
      "transcript": "लेकिन असली सच ये है — जो building गिरी, वो पूरी तरह illegal थी। ना कोई permission, ना कोई safety।"
    },
    {
      "id": "narration-accountability",
      "kind": "narration",
      "src": "audio://audio/42a8674fb4237b43.wav",
      "at": 974,
      "duration_frames": 218,
      "transcript": "अब building के मालिक और contractor को गिरफ़्तार कर लिया गया है, और CM ने हर परिवार को पाँच लाख रुपये देने का ऐलान किया।"
    },
    {
      "id": "narration-close",
      "kind": "narration",
      "src": "audio://audio/644b46587135dfad.wav",
      "at": 1227,
      "duration_frames": 228,
      "transcript": "पर सोचिए — क्या पाँच लाख रुपये उन बच्चों को वापस ला सकते हैं? आपको क्या लगता है, इस हादसे का असली ज़िम्मेदार कौन है? नीचे comment में ज़रूर बताइए।"
    }
  ],
